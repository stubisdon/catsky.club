# Server-only environment variables. Copy placeholders into .env.server on the
# production host or set them in the process manager. Do not commit real values.

GHOST_URL=https://catsky.club
GHOST_INTERNAL_URL=http://127.0.0.1:2368
GHOST_ADMIN_API_KEY=replace_with_ghost_admin_api_key
SIGNUPS_API_TOKEN=replace_with_random_token

# Gated SoundCloud share URLs. These must be real SoundCloud URLs on the server,
# but the public repo must only contain placeholders.
TRACK_URL_4=https://soundcloud.com/artist/private-track-placeholder
TRACK_URL_5=https://soundcloud.com/artist/private-track-placeholder
TRACK_URL_6=https://soundcloud.com/artist/private-track-placeholder
TRACK_URL_7=https://soundcloud.com/artist/private-track-placeholder
TRACK_URL_8=https://soundcloud.com/artist/private-track-placeholder

# Paid video embed URL, for example a YouTube embed URL.
VIDEO_EMBED_URL=https://www.youtube.com/embed/replace_with_rotated_video_id
