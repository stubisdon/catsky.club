## Local API server environment (Express `server.js`)
#
# Create a file named `.env.server` (gitignored) next to `server.js`
# and paste the values there.
#
# --- Server (server.js) ---
# Required for /api/submit (creates members in Ghost):
GHOST_ADMIN_API_KEY=YOUR_ID:YOUR_HEX_SECRET
#
# Optional:
# PORT=3001
# GHOST_URL=https://your-ghost-domain.com
# GHOST_ADMIN_API_VERSION=v5.0   (use v6.0 if your Ghost is 6.x)
# SIGNUPS_API_TOKEN=dev-only-token
#
# --- Frontend build (deploy.sh uses these for `npm run build`) ---
# Deploy uses VITE_GHOST_URL when set; otherwise it uses GHOST_URL (same value as server — you need one of them).
# VITE_GHOST_URL=https://your-ghost-domain.com
# VITE_GHOST_CONTENT_API_KEY=your_content_api_key_here
# Optional PostHog browser analytics:
# VITE_PUBLIC_POSTHOG_TOKEN=
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# VITE_PUBLIC_POSTHOG_ENABLED=true
