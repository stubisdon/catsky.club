{
  "name": "catsky.club",
  "version": "1.0.0",
  "description": "Custom minimalistic frontend for Ghost CMS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "node dev.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "start": "npm run build && npm run server",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run test:e2e:landing",
    "test:e2e:ui": "NODE_OPTIONS=\"--import tsx\" playwright test --ui --config=playwright.config.cjs",
    "test:e2e:headed": "NODE_OPTIONS=\"--import tsx\" playwright test --headed --config=playwright.config.cjs",
    "test:all": "npm run test && npm run test:e2e",
    "test:ci": "npm run test && npm run test:e2e",
    "test:e2e:auth": "npm run test:e2e:setup && NODE_OPTIONS=\"--import tsx\" playwright test e2e/auth.spec.ts --project=chromium --config=playwright.config.cjs",
    "test:e2e:landing": "npm run test:e2e:setup && NODE_OPTIONS=\"--import tsx\" playwright test e2e/landing.spec.ts --project=chromium --grep-invert=Performance --config=playwright.config.cjs",
    "test:e2e:landing:matrix": "npm run test:e2e:setup && NODE_OPTIONS=\"--import tsx\" playwright test e2e/landing.spec.ts --config=playwright.config.cjs",
    "test:e2e:matrix": "npm run test:e2e:setup && NODE_OPTIONS=\"--import tsx\" playwright test --config=playwright.config.cjs",
    "test:e2e:listen": "NODE_OPTIONS=\"--import tsx\" playwright test e2e/listen.spec.ts --config=playwright.config.cjs",
    "test:e2e:watch": "NODE_OPTIONS=\"--import tsx\" playwright test e2e/watch.spec.ts --config=playwright.config.cjs",
    "test:e2e:navigation": "NODE_OPTIONS=\"--import tsx\" playwright test e2e/navigation.spec.ts --config=playwright.config.cjs",
    "test:e2e:pages": "NODE_OPTIONS=\"--import tsx\" playwright test e2e/pages.spec.ts --config=playwright.config.cjs",
    "test:e2e:regression": "NODE_OPTIONS=\"--import tsx\" playwright test e2e/regression.spec.ts --config=playwright.config.cjs",
    "test:e2e:blast": "node scripts/e2e-blast-radius.mjs",
    "test:e2e:blast:run": "node scripts/e2e-blast-radius.mjs --run",
    "test:e2e:setup": "npx playwright install --with-deps chromium firefox webkit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.0.17",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "happy-dom": "^20.3.1",
    "jsdom": "^27.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^4.0.17"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/catsky-social/catsky.club.git"
  },
  "homepage": "https://catsky.club",
  "bugs": {
    "url": "https://github.com/catsky-social/catsky.club/issues"
  }
}
